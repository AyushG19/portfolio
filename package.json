{
  "name": "ayushG.com",
  "version": "0.1.0",
  "description": "A minimal, pixel-perfect dev portfolio, shadcn registry, and blog.",
  "homepage": "https://ayushG.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayushG19/ayushG19.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check-types": "tsc --noEmit --pretty",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,md,mdx}\" --cache",
    "registry:build": "bun run ./src/scripts/build-registry.mts && shadcn build ./src/__registry__/registry.autogenerated.json",
    "capture": "bun run ./src/scripts/capture.mts",
    "generate-libphonenumber-metadata": "libphonenumber-metadata-generator ./src/assets/libphonenumber.metadata.json --countries VN --extended",
    "upgrade:next": "npx @next/codemod@latest upgrade latest",
    "upgrade:tailwind": "npx @tailwindcss/upgrade@latest",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@bprogress/next": "^3.2.12",
    "@date-fns/tz": "^1.4.1",
    "@next/third-parties": "16.2.2",
    "@openpanel/web": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "jotai": "^2.18.1",
    "libphonenumber-js": "^1.12.4",
    "lru-cache": "^11.2.6",
    "lucide-react": "^1.6.0",
    "motion": "^12.36.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.368.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-fast-marquee": "^1.6.5",
    "react-hook-form": "^7.72.1",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-medium-image-zoom": "^5.4.3",
    "react-resizable-panels": "^4.10.0",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.3",
    "sonner": "^2.0.7",
